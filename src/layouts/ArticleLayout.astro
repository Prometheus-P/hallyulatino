---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import RelatedArticles from '@/components/RelatedArticles.astro';
import SocialShare from '@/components/SocialShare.astro';
import AdSlot from '@/components/AdSlot.astro';
import { generateArticleSchema, generateBreadcrumbSchema, SITE_CONFIG } from '@/utils/seo';
import { formatDateLong, formatDateISO } from '@/utils/date';

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  category: string;
  categorySlug: string;
  categoryLabel: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  relatedArticles?: Array<{
    title: string;
    slug: string;
    image: string;
    description: string;
  }>;
}

const {
  title,
  description,
  image,
  imageAlt,
  publishDate,
  updatedDate,
  author,
  category,
  categorySlug,
  categoryLabel,
  headings = [],
  relatedArticles = [],
} = Astro.props;

const currentUrl = Astro.url.pathname;

const breadcrumbItems = [
  { name: 'Inicio', url: '/' },
  { name: categoryLabel, url: `/${categorySlug}/` },
  { name: title, url: currentUrl },
];

const articleSchema = generateArticleSchema({
  title,
  description,
  image,
  publishDate,
  updatedDate,
  author,
  url: `${SITE_CONFIG.url}${currentUrl}`,
});

const breadcrumbSchema = generateBreadcrumbSchema(breadcrumbItems);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  type="article"
  publishDate={publishDate}
  updatedDate={updatedDate}
  author={author}
  canonical={`${SITE_CONFIG.url}${currentUrl}`}
  schemas={[articleSchema, breadcrumbSchema]}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Header Ad -->
    <div class="my-6">
      <AdSlot slot="header" />
    </div>

    <!-- Article Header -->
    <header class="mb-8">
      <div class="mb-4">
        <a
          href={`/${categorySlug}/`}
          class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-primary-200 transition-colors"
        >
          {categoryLabel}
        </a>
      </div>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4 leading-tight">
        {title}
      </h1>

      <p class="text-xl text-gray-600 mb-6">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <span>Por <strong class="text-gray-700">{author}</strong></span>
        <span>|</span>
        <time datetime={formatDateISO(publishDate)}>
          {formatDateLong(publishDate)}
        </time>
        {updatedDate && (
          <>
            <span>|</span>
            <span>
              Actualizado: <time datetime={formatDateISO(updatedDate)}>{formatDateLong(updatedDate)}</time>
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    <div class="mb-8">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-auto rounded-xl shadow-lg object-cover aspect-video"
        loading="eager"
      />
    </div>

    <!-- Content Grid -->
    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-8">
        <!-- Social Share (Top) -->
        <SocialShare title={title} url={`${SITE_CONFIG.url}${currentUrl}`} />

        <!-- Article Content -->
        <div class="article-content mt-6">
          <slot />
        </div>

        <!-- In-Article Ad -->
        <div class="my-8">
          <AdSlot slot="in-article" />
        </div>

        <!-- Social Share (Bottom) -->
        <div class="mt-8 pt-8 border-t border-gray-200">
          <p class="text-gray-600 mb-4">¿Te gustó este artículo? ¡Compártelo!</p>
          <SocialShare title={title} url={`${SITE_CONFIG.url}${currentUrl}`} />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 mt-8 lg:mt-0">
        <div class="sticky top-4 space-y-6">
          <!-- Table of Contents -->
          {headings.length > 0 && (
            <TableOfContents headings={headings} />
          )}

          <!-- Sidebar Ad -->
          <AdSlot slot="sidebar" />
        </div>
      </aside>
    </div>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-200">
        <RelatedArticles
          articles={relatedArticles}
          categorySlug={categorySlug}
        />
      </section>
    )}

    <!-- Footer Ad -->
    <div class="mt-8">
      <AdSlot slot="footer" />
    </div>
  </article>
</BaseLayout>
