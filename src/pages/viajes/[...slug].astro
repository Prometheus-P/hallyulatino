---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('viajes');
  return articles.map((article) => ({
    params: { slug: article.slug.replace('es/', '') },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'viajes'>;
}

const { article } = Astro.props;
const { Content, headings } = await article.render();

// Get related articles (same category)
const allArticles = await getCollection('viajes');
const relatedArticles = allArticles
  .filter((a) => a.slug !== article.slug)
  .filter((a) => a.data.category === article.data.category)
  .slice(0, 3)
  .map((a) => ({
    title: a.data.title,
    slug: a.slug.replace('es/', ''),
    image: a.data.image,
    description: a.data.description,
  }));

const categoryLabels = {
  transporte: 'Transporte',
  alojamiento: 'Alojamiento',
  comida: 'Comida',
  lugares: 'Lugares',
  consejos: 'Consejos',
};
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  image={article.data.image}
  imageAlt={article.data.imageAlt}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  author={article.data.author}
  category="viajes"
  categorySlug="viajes"
  categoryLabel="Viajes a Corea"
  headings={headings}
  relatedArticles={relatedArticles}
>
  <!-- Category Badge -->
  <div class="mb-6 not-prose">
    <span class="inline-block bg-secondary-100 text-secondary-700 px-3 py-1 rounded-full text-sm font-medium">
      {categoryLabels[article.data.category]}
    </span>
  </div>

  <!-- Article Content -->
  <Content />
</ArticleLayout>
