---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AdSlot from '@/components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { generateOrganizationSchema, generateWebSiteSchema, SITE_CONFIG } from '@/utils/seo';

// Get latest articles from all collections
const kdramas = await getCollection('kdrama');
const kpop = await getCollection('kpop');
const viajes = await getCollection('viajes');

// Sort by publish date and get latest
const allArticles = [
  ...kdramas.map(a => ({ ...a, category: 'kdramas' })),
  ...kpop.map(a => ({ ...a, category: 'kpop' })),
  ...viajes.map(a => ({ ...a, category: 'viajes' })),
].sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const latestArticles = allArticles.slice(0, 6);
const latestKdramas = kdramas.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 3);
const latestKpop = kpop.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 3);
const latestViajes = viajes.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 3);

const organizationSchema = generateOrganizationSchema();
const websiteSchema = generateWebSiteSchema();
---

<BaseLayout
  title=""
  description={SITE_CONFIG.description}
  canonical={SITE_CONFIG.url}
  schemas={[organizationSchema, websiteSchema]}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-primary-600 to-secondary-600 text-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Bienvenido a Hallyu Latino
      </h1>
      <p class="text-xl md:text-2xl text-white/90 max-w-3xl mx-auto mb-8">
        Tu portal de K-dramas, K-pop y cultura coreana en español.
        Descubre las últimas noticias, reseñas y guías sobre el mundo del entretenimiento coreano.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kdramas/" class="btn-primary bg-white text-primary-600 hover:bg-gray-100">
          Explorar K-Dramas
        </a>
        <a href="/kpop/" class="btn-secondary border-2 border-white bg-transparent hover:bg-white/10">
          Descubrir K-Pop
        </a>
      </div>
    </div>
  </section>

  <!-- Header Ad -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <AdSlot slot="header" />
  </div>

  <!-- Latest Articles -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
        Últimos Artículos
      </h2>
    </div>

    {latestArticles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            slug={`/${article.category}/${article.slug.replace('es/', '')}`}
            publishDate={article.data.publishDate}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12 bg-gray-50 rounded-lg">
        <p class="text-gray-500 text-lg">
          Pronto publicaremos contenido increíble. ¡Vuelve pronto!
        </p>
      </div>
    )}
  </section>

  <!-- In-Article Ad -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <AdSlot slot="in-article" />
  </div>

  <!-- K-Dramas Section -->
  {latestKdramas.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
          K-Dramas Destacados
        </h2>
        <a href="/kdramas/" class="text-primary-600 hover:text-primary-700 font-medium">
          Ver todos →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestKdramas.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            slug={`/kdramas/${article.slug.replace('es/', '')}`}
            publishDate={article.data.publishDate}
          />
        ))}
      </div>
    </section>
  )}

  <!-- K-Pop Section -->
  {latestKpop.length > 0 && (
    <section class="bg-gray-50 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
            K-Pop Destacado
          </h2>
          <a href="/kpop/" class="text-primary-600 hover:text-primary-700 font-medium">
            Ver todos →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestKpop.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              image={article.data.image}
              imageAlt={article.data.imageAlt}
              slug={`/kpop/${article.slug.replace('es/', '')}`}
              publishDate={article.data.publishDate}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Travel Section -->
  {latestViajes.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">
          Guías de Viaje a Corea
        </h2>
        <a href="/viajes/" class="text-primary-600 hover:text-primary-700 font-medium">
          Ver todos →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestViajes.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            slug={`/viajes/${article.slug.replace('es/', '')}`}
            publishDate={article.data.publishDate}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter CTA -->
  <section class="bg-gradient-to-r from-primary-600 to-secondary-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        ¿Te gusta el contenido?
      </h2>
      <p class="text-lg text-white/90 mb-6 max-w-2xl mx-auto">
        Síguenos en nuestras redes sociales para no perderte ninguna actualización
        sobre tus dramas y artistas favoritos.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="#"
          class="inline-flex items-center gap-2 bg-white text-primary-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          Síguenos
        </a>
      </div>
    </div>
  </section>

  <!-- Footer Ad -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <AdSlot slot="footer" />
  </div>
</BaseLayout>
