---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('kpop');
  return articles.map((article) => ({
    params: { slug: article.slug.replace('es/', '') },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'kpop'>;
}

const { article } = Astro.props;
const { Content, headings } = await article.render();

// Get related articles (same company or artist type)
const allArticles = await getCollection('kpop');
const relatedArticles = allArticles
  .filter((a) => a.slug !== article.slug)
  .filter((a) =>
    a.data.company === article.data.company ||
    a.data.artistType === article.data.artistType
  )
  .slice(0, 3)
  .map((a) => ({
    title: a.data.title,
    slug: a.slug.replace('es/', ''),
    image: a.data.image,
    description: a.data.description,
  }));

const artistTypeLabels = {
  grupo: 'Grupo',
  solista: 'Solista',
};
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  image={article.data.image}
  imageAlt={article.data.imageAlt}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  author={article.data.author}
  category="kpop"
  categorySlug="kpop"
  categoryLabel="K-Pop"
  headings={headings}
  relatedArticles={relatedArticles}
>
  <!-- Artist Info Box -->
  <div class="bg-gray-50 rounded-lg p-6 mb-8 not-prose">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Información del Artista</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <p class="text-sm text-gray-500">Tipo</p>
        <p class="font-medium text-gray-900">{artistTypeLabels[article.data.artistType]}</p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Agencia</p>
        <p class="font-medium text-gray-900">{article.data.company}</p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Año de debut</p>
        <p class="font-medium text-gray-900">{article.data.debutYear}</p>
      </div>
      {article.data.members && (
        <div>
          <p class="text-sm text-gray-500">Miembros</p>
          <p class="font-medium text-gray-900">{article.data.members.length}</p>
        </div>
      )}
    </div>
  </div>

  <!-- Members Section -->
  {article.data.members && article.data.members.length > 0 && (
    <div class="mb-8 not-prose">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Miembros</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {article.data.members.map((member) => (
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            <p class="font-medium text-gray-900">{member.name}</p>
            <p class="text-sm text-gray-500">{member.nameKorean}</p>
            <p class="text-sm text-primary-600 mt-1">{member.position}</p>
            {member.birthYear && (
              <p class="text-xs text-gray-400 mt-1">Nacido en {member.birthYear}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Article Content -->
  <Content />
</ArticleLayout>
