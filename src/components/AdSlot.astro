---
interface Props {
  slot: 'header' | 'sidebar' | 'in-article' | 'footer';
  className?: string;
}

const { slot, className = '' } = Astro.props;

const slotConfig = {
  header: { minHeight: '90px', label: 'Ad: Header (728x90)' },
  sidebar: { minHeight: '250px', label: 'Ad: Sidebar (300x250)' },
  'in-article': { minHeight: '280px', label: 'Ad: In-Article (Responsive)' },
  footer: { minHeight: '90px', label: 'Ad: Footer (728x90)' },
};

const config = slotConfig[slot];
---

<div
  class:list={[
    'ad-slot',
    `ad-${slot}`,
    'bg-gray-100 flex items-center justify-center rounded-lg',
    className
  ]}
  style={`min-height: ${config.minHeight}`}
  data-ad-slot={slot}
  aria-label="Espacio publicitario"
>
  <span class="text-gray-400 text-sm">{config.label}</span>
</div>

<style>
  .ad-slot {
    /* CLS prevention - maintain space even when ad is loading */
    contain: layout size;
  }

  .ad-header, .ad-footer {
    max-width: 728px;
    margin-left: auto;
    margin-right: auto;
  }

  .ad-sidebar {
    max-width: 300px;
  }

  .ad-in-article {
    max-width: 100%;
  }

  /* Hide on very small screens if needed */
  @media (max-width: 320px) {
    .ad-header, .ad-footer {
      display: none;
    }
  }
</style>
