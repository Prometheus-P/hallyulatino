---
import { formatDateShort } from '@/utils/date';

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  slug: string;
  publishDate: Date;
}

const { title, description, image, imageAlt, slug, publishDate } = Astro.props;
---

<article class="bg-white rounded-xl shadow-md overflow-hidden card-hover">
  <a href={slug} class="block">
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="p-5">
      <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2 hover:text-primary-600 transition-colors">
        {title}
      </h3>
      <p class="text-gray-600 text-sm line-clamp-3 mb-3">
        {description}
      </p>
      <time
        datetime={publishDate.toISOString()}
        class="text-gray-400 text-xs"
      >
        {formatDateShort(publishDate)}
      </time>
    </div>
  </a>
</article>
