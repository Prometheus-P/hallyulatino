---
interface Article {
  title: string;
  slug: string;
  image: string;
  description: string;
}

interface Props {
  articles: Article[];
  categorySlug: string;
}

const { articles, categorySlug } = Astro.props;
---

{articles.length > 0 && (
  <div>
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Artículos Relacionados</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {articles.slice(0, 3).map((article) => (
        <a
          href={`/${categorySlug}/${article.slug}`}
          class="group block bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow duration-200"
        >
          <div class="aspect-video overflow-hidden">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2">
              {article.title}
            </h3>
            <p class="text-gray-500 text-sm mt-2 line-clamp-2">
              {article.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
